# ============================================================
# OpenCode Anthropic Proxy 配置
# ============================================================

# 【必填】OpenCode API Key
OPENCODE_API_KEY=sk-your-opencode-api-key-here

# 【选填】OpenCode Go 套餐 API 基础地址（默认 https://opencode.ai/zen/go/v1）
OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1

# 【选填】目标模型名称（默认 deepseek-v4-flash）
TARGET_MODEL=deepseek-v4-flash

# 【选填】允许的 Anthropic 模型名列表（逗号分隔，不在列表中的模型会被拒绝）
# 留空则允许所有模型
ALLOWED_MODELS=claude-sonnet-4-20250514,claude-3.5-sonnet,claude-opus-4

# 【选填】Anthropic API 版本头
ANTHROPIC_VERSION=2023-06-01
